{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node@2", "config": { "maxDuration": 20 } },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "/api/analyze.js" },
    { "src": "/api/analyze", "dest": "/api/analyze.js" },
    { "src": "/", "dest": "/index.html" }
  ]
}
